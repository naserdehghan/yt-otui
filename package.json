{
  "name": "yt-otui",
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.tsx",
    "build": "bun build ./src/index.tsx --outdir ./dist --target bun",
    "preview": "bun run dist/index.js",
    "compile": "bun build --compile ./src/index.tsx --outfile yt-otui",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentui/core": "^0.4.3",
    "@opentui/react": "^0.4.3",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "bun-types": "^1.3.14",
    "typescript": "^7.0.2"
  }
}
